<Window x:Class="ChequeMate.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ChequeMate.App.Views"
        xmlns:vm="clr-namespace:ChequeMate.App.ViewModels"
        Title="ChequeMate - Cheque Printing System" 
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="ChequeMate" FontSize="20" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryBrush}" 
                           Margin="16,0,16,24"/>

                <Button Content="📝 Template Editor" 
                        Command="{Binding NavigateToTemplatesCommand}"
                        Style="{StaticResource NavButton}" Margin="8,2"/>
                <Button Content="✏️ New Cheque" 
                        Command="{Binding NavigateToChequeEntryCommand}"
                        Style="{StaticResource NavButton}" Margin="8,2"/>
                <Button Content="🖨️ Print Queue" 
                        Command="{Binding NavigateToPrintQueueCommand}"
                        Style="{StaticResource NavButton}" Margin="8,2"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1" Margin="16">
            <ContentControl.Content>
                <Binding Path="CurrentView"/>
            </ContentControl.Content>
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:TemplateEditorViewModel}">
                    <views:TemplateEditorView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ChequeEntryViewModel}">
                    <views:ChequeEntryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:PrintQueueViewModel}">
                    <views:PrintQueueView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
