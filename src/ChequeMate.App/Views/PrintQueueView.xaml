<UserControl x:Class="ChequeMate.App.Views.PrintQueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Print Queue" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <!-- Printer selection and actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Printer:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding Printers}" SelectedItem="{Binding SelectedPrinter}" 
                      Width="250" Margin="0,0,12,0"/>
            <Button Content="Print Selected" Command="{Binding PrintSelectedCommand}" 
                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                    IsEnabled="{Binding IsPrinting, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="Print All" Command="{Binding PrintAllCommand}" 
                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                    IsEnabled="{Binding IsPrinting, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="Refresh" Command="{Binding RefreshQueueCommand}" 
                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
            <Button Content="Remove" Command="{Binding RemoveFromQueueCommand}" 
                    Foreground="White" Background="#DC2626" Padding="12,6"/>
        </StackPanel>

        <!-- Queue list -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <DataGrid ItemsSource="{Binding PendingCheques}" SelectedItem="{Binding SelectedCheque}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Payee" Binding="{Binding Payee}" Width="*"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding AmountFigures, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding ChequeDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Cheque #" Binding="{Binding ChequeNumber}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding PrintStatus}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" 
                   Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
