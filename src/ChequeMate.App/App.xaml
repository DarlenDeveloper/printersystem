<Application x:Class="ChequeMate.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ChequeMate.App.Converters"
             xmlns:enums="clr-namespace:ChequeMate.Core.Enums;assembly=ChequeMate.Core"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:MmToPixelConverter x:Key="MmToPixelConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>

            <ObjectDataProvider x:Key="FieldTypeValues" MethodName="GetValues" 
                                ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:FieldType"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </Application.Resources>
</Application>
